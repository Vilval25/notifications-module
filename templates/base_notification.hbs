<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
  <h2 style="color: #333; margin-bottom: 20px;">Notificación</h2>
  <p style="font-size: 16px; line-height: 1.6; color: #333;">Hola <strong>{{name}}</strong>,</p>
  <p style="font-size: 16px; line-height: 1.6; color: #333; margin-top: 15px;">{{message}}</p>
  <p style="margin-top: 30px; font-size: 14px; color: #666;">Fecha: {{date}}</p>
  <p style="font-size: 14px; color: #999; margin-top: 20px;">Este es un mensaje automático, por favor no respondas a este correo.</p>
</div>
