<!-- META:START
{
  "subject": "¡Bienvenido a Campus360! - Tu cuenta ha sido creada",
  "event_type": "creacion_cuenta",
  "variables": ["nombre", "email", "enlace", "telefono"]
}
META:END -->
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px; background-color: #fff;">
  <div style="background-color: #2563eb; padding: 30px; border-radius: 8px 8px 0 0; text-align: center;">
    <h1 style="color: #fff; margin: 0;">¡Bienvenido a Campus360!</h1>
  </div>

  <div style="padding: 30px; border: 1px solid #e5e7eb; border-top: none; border-radius: 0 0 8px 8px;">
    <p style="font-size: 16px; color: #333;">Hola <strong style="color: #2563eb;">{{nombre}}</strong>,</p>

    <p style="font-size: 16px; color: #333;">Tu cuenta ha sido creada exitosamente.</p>

    <div style="background-color: #eff6ff; padding: 15px; margin: 20px 0; border-radius: 4px;">
      <p style="margin: 0; color: #1e40af;">📧 Email: <strong>{{email}}</strong></p>
    </div>

    <div style="text-align: center; margin: 25px 0;">
      <a href="{{enlace}}" style="display: inline-block; background-color: #2563eb; color: white; padding: 12px 30px; text-decoration: none; border-radius: 6px; font-weight: bold;">Acceder a Mi Cuenta</a>
    </div>

    <p style="font-size: 14px; color: #666; margin-top: 20px;">
      Si tienes dudas, contáctanos al: <strong>{{telefono}}</strong>
    </p>

    <p style="font-size: 12px; color: #999; margin-top: 20px; text-align: center;">
      Este es un mensaje automático, por favor no responder.
    </p>
  </div>
</div>
