<!-- META:START
{
  "subject": "Trámite Observado - Requiere Corrección",
  "event_type": "tramite_observado",
  "variables": ["nombre", "email", "enlace", "telefono"]
}
META:END -->
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px; background-color: #fff;">
  <div style="background-color: #ea580c; padding: 20px; border-radius: 8px 8px 0 0;">
    <h2 style="color: #fff; margin: 0;">⚠️ Trámite Observado</h2>
  </div>

  <div style="padding: 30px; border: 1px solid #e5e7eb; border-top: none; border-radius: 0 0 8px 8px;">
    <p style="font-size: 16px; color: #333;">Estimado/a <strong>{{nombre}}</strong>,</p>

    <p style="font-size: 16px; color: #333;">Su trámite ha sido <strong style="color: #ea580c;">observado</strong> y requiere correcciones.</p>

    <div style="background-color: #fff7ed; border-left: 4px solid #ea580c; padding: 15px; margin: 20px 0;">
      <p style="margin: 0; color: #9a3412;">{{observaciones}}</p>
    </div>

    <div style="text-align: center; margin: 25px 0;">
      <a href="{{enlace}}" style="display: inline-block; background-color: #ea580c; color: white; padding: 12px 30px; text-decoration: none; border-radius: 6px; font-weight: bold;">Corregir Trámite</a>
    </div>

    <p style="font-size: 14px; color: #666;">Contacto: <strong>{{telefono}}</strong></p>
  </div>
</div>
