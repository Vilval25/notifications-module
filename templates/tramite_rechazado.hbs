<!-- META:START
{
  "subject": "Trámite Rechazado - Acción Requerida",
  "event_type": "tramite_rechazado",
  "variables": ["nombre", "email", "enlace", "telefono"]
}
META:END -->
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px; background-color: #fff;">
  <div style="background-color: #dc2626; padding: 20px; border-radius: 8px 8px 0 0;">
    <h2 style="color: #fff; margin: 0;">❌ Trámite Rechazado</h2>
  </div>

  <div style="padding: 30px; border: 1px solid #e5e7eb; border-top: none; border-radius: 0 0 8px 8px;">
    <p style="font-size: 16px; color: #333;">Estimado/a <strong>{{nombre}}</strong>,</p>

    <p style="font-size: 16px; color: #333;">Lamentamos informarle que su trámite ha sido <strong style="color: #dc2626;">rechazado</strong>.</p>

    <div style="background-color: #fef2f2; border-left: 4px solid #dc2626; padding: 15px; margin: 20px 0;">
      <p style="margin: 0; color: #991b1b;">Motivo: {{motivo_rechazo}}</p>
    </div>

    <div style="text-align: center; margin: 25px 0;">
      <a href="{{enlace}}" style="display: inline-block; background-color: #2563eb; color: white; padding: 12px 30px; text-decoration: none; border-radius: 6px; font-weight: bold;">Ver Detalles</a>
    </div>

    <p style="font-size: 14px; color: #666;">Contacto: <strong>{{telefono}}</strong></p>
  </div>
</div>
