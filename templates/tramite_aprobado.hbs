<!-- META:START
{
  "subject": "¡Trámite Aprobado! - Campus360",
  "event_type": "tramite_aprobado",
  "variables": ["nombre", "email", "enlace", "telefono"]
}
META:END -->
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px; background-color: #fff;">
  <div style="background-color: #16a34a; padding: 20px; border-radius: 8px 8px 0 0;">
    <h2 style="color: #fff; margin: 0;">✅ Trámite Aprobado</h2>
  </div>

  <div style="padding: 30px; border: 1px solid #e5e7eb; border-top: none; border-radius: 0 0 8px 8px;">
    <p style="font-size: 16px; color: #333;">Estimado/a <strong>{{nombre}}</strong>,</p>

    <p style="font-size: 16px; color: #333;">¡Felicidades! Su trámite ha sido <strong style="color: #16a34a;">aprobado exitosamente</strong>.</p>

    <div style="background-color: #f0fdf4; border-left: 4px solid #16a34a; padding: 15px; margin: 20px 0;">
      <p style="margin: 0; color: #166534;">Tu solicitud ha sido procesada correctamente.</p>
    </div>

    <div style="text-align: center; margin: 25px 0;">
      <a href="{{enlace}}" style="display: inline-block; background-color: #16a34a; color: white; padding: 12px 30px; text-decoration: none; border-radius: 6px; font-weight: bold;">Ver Detalles</a>
    </div>

    <p style="font-size: 14px; color: #666;">Dudas: <strong>{{telefono}}</strong></p>
  </div>
</div>
