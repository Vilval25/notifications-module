<!-- META:START
{
  "subject": "Confirmación de Cambio de Contraseña - Campus360",
  "event_type": "confirmacion_cambio_password",
  "variables": ["nombre", "email", "enlace", "telefono"]
}
META:END -->
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px; background-color: #fff;">
  <div style="background-color: #7c3aed; padding: 20px; border-radius: 8px 8px 0 0;">
    <h2 style="color: #fff; margin: 0;">🔒 Cambio de Contraseña</h2>
  </div>

  <div style="padding: 30px; border: 1px solid #e5e7eb; border-top: none; border-radius: 0 0 8px 8px;">
    <p style="font-size: 16px; color: #333;">Estimado/a <strong>{{nombre}}</strong>,</p>

    <p style="font-size: 16px; color: #333;">Tu contraseña ha sido <strong style="color: #7c3aed;">cambiada exitosamente</strong>.</p>

    <div style="background-color: #faf5ff; border-left: 4px solid #7c3aed; padding: 15px; margin: 20px 0;">
      <p style="margin: 0; color: #6b21a8;">Si no realizaste este cambio, contacta inmediatamente con soporte.</p>
    </div>

    <div style="text-align: center; margin: 25px 0;">
      <a href="{{enlace}}" style="display: inline-block; background-color: #7c3aed; color: white; padding: 12px 30px; text-decoration: none; border-radius: 6px; font-weight: bold;">Iniciar Sesión</a>
    </div>

    <p style="font-size: 14px; color: #666;">Soporte: <strong>{{telefono}}</strong></p>
  </div>
</div>
